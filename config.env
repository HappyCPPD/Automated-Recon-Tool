# XSS Recon Configuration File
# Source this file to override defaults: source config.env

# Performance Settings
# Number of threads for parallel operations
THREADS=50

# Number of concurrent scan instances
CONCURRENT_SCANS=5

# Timeout for individual scan operations (seconds)
SCAN_TIMEOUT=300

# Tool Installation Settings
# Set to 'true' to attempt automatic tool installation
AUTO_INSTALL_TOOLS=true

# Skip installation check on startup
SKIP_INSTALL_CHECK=false

# Discord Notifications
# Enable Discord notifications (true/false)
DISCORD_ENABLED=false

# Discord Webhook URL - set your webhook here
DISCORD_WEBHOOK_URL=""

# Scanning Behavior
# Continue scanning even if some tools fail
GRACEFUL_DEGRADATION=true

# Report Settings
# Generate HTML reports
GENERATE_HTML_REPORT=true

# Include detailed finding information
DETAILED_FINDINGS=true

# Fuzzing Settings
# Path to custom wordlist for fuzzing
# Leave empty to use default system wordlists
CUSTOM_WORDLIST=""

# API Endpoints to check
API_ENDPOINTS="api v1 v2 rest graphql swagger docs admin dev test staging .well-known"

# XSS Scanning
# Custom XSS payloads file path (optional)
# CUSTOM_XSS_PAYLOADS="/path/to/payloads.txt"

# Subdomain Permutation Prefixes
SUBDOMAIN_PREFIXES=(
    "dev"
    "staging"
    "test"
    "api"
    "admin"
    "internal"
    "prod"
    "cdn"
    "www"
    "mail"
)

# Content Discovery Patterns
# File extensions to look for
INTERESTING_EXTENSIONS=(
    "php"
    "asp"
    "aspx"
    "jsp"
    "js"
    "json"
    "xml"
    "txt"
    "pdf"
    "sql"
    "bak"
    "old"
    "backup"
    "config"
    "env"
    "keys"
    "pem"
    "crt"
)

# JavaScript Secret Patterns
JS_SECRET_PATTERNS=(
    "api[_-]?key"
    "secret"
    "token"
    "password"
    "client[_-]?id"
    "client[_-]?secret"
    "authorization"
    "bearer"
    "aws[_-]?"
    "gcp[_-]?"
    "firebase"
)

# Logging
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# Keep old reports
ARCHIVE_REPORTS=true

# Maximum report file size before archiving (MB)
MAX_REPORT_SIZE=100

# Tool Configuration
# Nuclei severity levels to scan
NUCLEI_SEVERITIES="critical,high,medium"

# Max retries for failed operations
MAX_RETRIES=3

# Retry delay in seconds
RETRY_DELAY=5
